# Mode: Hybride MiMo (Sonnet/Haiku -> MiMo-V2.5-Pro, Opus -> Anthropic)
# Shell directives (not passed to proxy)
_SHELL_SONNET_KEY=.mimo-api-key
_SHELL_HAIKU_KEY=.mimo-api-key

# Proxy env vars — Xiaomi MiMo Token Plan (EU endpoint)
SONNET_PROVIDER_BASE_URL=https://token-plan-ams.xiaomimimo.com/anthropic
HAIKU_PROVIDER_BASE_URL=https://token-plan-ams.xiaomimimo.com/anthropic
PROVIDER_SONNET_MODEL=mimo-v2.5-pro
PROVIDER_HAIKU_MODEL=mimo-v2.5-pro
PROVIDER_PASS_CACHE_CONTROL=1
# MiMo docs: keep thinking blocks in history for best multi-turn tool performance
PROVIDER_STRIP_THINKING=0
