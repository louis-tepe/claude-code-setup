# Mode: Hybride MiniMax (Sonnet/Haiku -> MiniMax M2.7)
# Shell directives (not passed to proxy)
_SHELL_SONNET_KEY=.minimax-api-key
_SHELL_HAIKU_KEY=.minimax-api-key

# Proxy env vars
SONNET_PROVIDER_BASE_URL=https://api.minimax.io/anthropic
HAIKU_PROVIDER_BASE_URL=https://api.minimax.io/anthropic
PROVIDER_SONNET_MODEL=MiniMax-M2.7
PROVIDER_HAIKU_MODEL=MiniMax-M2.7
PROVIDER_PASS_CACHE_CONTROL=1
# MiniMax docs: interleaved CoT requires thinking blocks preserved across turns
PROVIDER_STRIP_THINKING=0
