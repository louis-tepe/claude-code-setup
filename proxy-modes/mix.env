# Mode: Split global (Sonnet -> MiMo-V2.5-Pro, Haiku -> MiniMax M2.7, Opus -> Anthropic)
# Shell directives (not passed to proxy)
_SHELL_SONNET_KEY=.mimo-api-key
_SHELL_HAIKU_KEY=.minimax-api-key

# Sonnet -> Xiaomi MiMo-V2.5-Pro (intelligence, caching supported)
SONNET_PROVIDER_BASE_URL=https://token-plan-ams.xiaomimimo.com/anthropic
PROVIDER_SONNET_MODEL=mimo-v2.5-pro
# Haiku -> MiniMax M2.7 (vitesse, caching supported)
HAIKU_PROVIDER_BASE_URL=https://api.minimax.io/anthropic
PROVIDER_HAIKU_MODEL=MiniMax-M2.7
PROVIDER_PASS_CACHE_CONTROL=1
# MiMo + MiniMax both require thinking blocks in history for best multi-turn perf
PROVIDER_STRIP_THINKING=0
