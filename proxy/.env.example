# ── Z.AI Provider Config ──
# API key and base URL for Sonnet/Haiku routing to Z.AI
SONNET_PROVIDER_API_KEY=your_zai_api_key_here
SONNET_PROVIDER_BASE_URL=https://api.z.ai/api/anthropic/v1
HAIKU_PROVIDER_API_KEY=your_zai_api_key_here
HAIKU_PROVIDER_BASE_URL=https://api.z.ai/api/anthropic/v1

# Opus routing (leave empty to passthrough to Anthropic OAuth)
# OPUS_PROVIDER_API_KEY=
# OPUS_PROVIDER_BASE_URL=

# ── Per-tier model mapping ──
# Which model name to send to Z.AI for each tier
# Falls back to ZAI_TARGET_MODEL if not set
ZAI_TARGET_MODEL=glm-5
# ZAI_SONNET_MODEL=glm-5
# ZAI_HAIKU_MODEL=glm-4.7
# ZAI_OPUS_MODEL=glm-5

# ── Compatibility toggles ──
# Allow forced tool_choice to pass through to Z.AI (default: false, fallback to Anthropic)
# ALLOW_FORCED_TOOL_CHOICE=false
# Let cache_control pass through to Z.AI instead of stripping (default: false)
# ZAI_PASS_CACHE_CONTROL=false

# ── Proxy config ──
PORT=8082
LOG_LEVEL=INFO
MAX_RETRIES=3
MAX_CONCURRENT_REQUESTS=15

# ── GLM-5 pricing (USD per million tokens, for cost display scaling) ──
GLM5_INPUT_PRICE=1.00
GLM5_OUTPUT_PRICE=3.20
